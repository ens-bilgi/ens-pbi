{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "vLineUSD",
  "position": { "x": 30, "y": 30, "z": 1000, "width": 600, "height": 350, "tabOrder": 0 },
  "filterConfig": {
    "filters": [
      {
        "name": "fltUSD",
        "field": { "Column": { "Expression": { "SourceRef": { "Entity": "Exchange Rate" } }, "Property": "base_currency" } },
        "type": "Categorical",
        "filter": {
          "Version": 2,
          "From": [{ "Name": "e", "Entity": "Exchange Rate", "Type": 0 }],
          "Where": [{ "Condition": { "In": { "Expressions": [{ "Column": { "Expression": { "SourceRef": { "Source": "e" } }, "Property": "base_currency" } }], "Values": [[{ "Literal": { "Value": "'USD'" } }]] } } }]
        }
      }
    ]
  },
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            { "field": { "Column": { "Expression": { "SourceRef": { "Entity": "Exchange Rate" } }, "Property": "date" } }, "queryRef": "Exchange Rate.date", "nativeQueryRef": "date" }
          ]
        },
        "Y": {
          "projections": [
            { "field": { "Measure": { "Expression": { "SourceRef": { "Entity": "Exchange Rate" } }, "Property": "Selling Rate" } }, "queryRef": "Exchange Rate.Selling Rate", "nativeQueryRef": "Selling Rate" }
          ]
        }
      }
    },
    "visualContainerObjects": {
      "title": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'USD/TRY Exchange Rate'" } } } } }]
    },
    "drillFilterOtherVisuals": true
  }
}
