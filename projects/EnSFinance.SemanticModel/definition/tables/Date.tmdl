table Date
	dataCategory: Time
	lineageTag: d0000001-0000-0000-0000-000000000001

	column Date
		isKey
		dataType: dateTime
		formatString: dd/MM/yyyy
		lineageTag: d0000001-0001-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

	column DateKey
		dataType: int64
		isHidden
		lineageTag: d0000001-0002-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: DateKey

		annotation SummarizationSetBy = Automatic

	column Year
		dataType: int64
		lineageTag: d0000001-0003-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: Year

		annotation SummarizationSetBy = Automatic

	column Quarter
		dataType: int64
		lineageTag: d0000001-0004-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: Quarter

		annotation SummarizationSetBy = Automatic

	column Month
		dataType: int64
		lineageTag: d0000001-0005-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: Month

		annotation SummarizationSetBy = Automatic

	column MonthName
		dataType: string
		lineageTag: d0000001-0006-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: MonthName
		sortByColumn: Month

		annotation SummarizationSetBy = Automatic

	column Day
		dataType: int64
		lineageTag: d0000001-0007-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: Day

		annotation SummarizationSetBy = Automatic

	column DayOfWeek
		dataType: int64
		lineageTag: d0000001-0008-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: DayOfWeek

		annotation SummarizationSetBy = Automatic

	column WeekOfYear
		dataType: int64
		lineageTag: d0000001-0009-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: WeekOfYear

		annotation SummarizationSetBy = Automatic

	column IsWeekend
		dataType: boolean
		lineageTag: d0000001-000a-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: IsWeekend

		annotation SummarizationSetBy = Automatic

	column FiscalYear
		dataType: int64
		lineageTag: d0000001-000b-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: FiscalYear

		annotation SummarizationSetBy = Automatic

	column FiscalQuarter
		dataType: int64
		lineageTag: d0000001-000c-0000-0000-000000000001
