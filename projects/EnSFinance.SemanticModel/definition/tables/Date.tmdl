		sourceColumn: FiscalQuarter

		annotation SummarizationSetBy = Automatic

	hierarchy 'Calendar Hierarchy'
		lineageTag: d0000001-00h1-0000-0000-000000000001

		level Year
			lineageTag: d0000001-00h2-0000-0000-000000000001
			column: Year

		level Quarter
			lineageTag: d0000001-00h3-0000-0000-000000000001
			column: Quarter

		level Month
			lineageTag: d0000001-00h4-0000-0000-000000000001
			column: MonthName

	partition Date = m
		mode: import
		queryGroup: Tables
		source =
				let
				    Source = Sql.Database(SqlEndpoint, Database),
				    Data = Source{[Schema="dbo",Item="dim_date"]}[Data]
				in
				    Data
