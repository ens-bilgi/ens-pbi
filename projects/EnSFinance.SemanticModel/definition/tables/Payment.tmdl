		sourceColumn: PaymentId

		annotation SummarizationSetBy = Automatic

	column DateKey
		dataType: int64
		isHidden
		lineageTag: f0000003-0002-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: DateKey

		annotation SummarizationSetBy = Automatic

	column PaymentMethodKey
		dataType: int64
		isHidden
