	column CreatedBy
		dataType: string
		isHidden
		lineageTag: f0000003-000b-0000-0000-000000000001
		summarizeBy: none
		sourceColumn: CreatedBy

		annotation SummarizationSetBy = Automatic

	/// Total outgoing payments in original currency
	measure 'Total Outgoing' =
			CALCULATE (
				SUM ( Payment[Amount] ),
				Payment[Direction] = "outgoing"
			)
		formatString: #,##0.00
		displayFolder: Payments
		lineageTag: f0000003-0m01-0000-0000-000000000001

	/// Total incoming payments in original currency
	measure 'Total Incoming' =
			CALCULATE (
				SUM ( Payment[Amount] ),
				Payment[Direction] = "incoming"
			)
		formatString: #,##0.00
		displayFolder: Payments
		lineageTag: f0000003-0m02-0000-0000-000000000001

	/// Net cash flow (incoming - outgoing)
	measure 'Net Cash Flow' =
			[Total Incoming] - [Total Outgoing]
		formatString: #,##0.00
		displayFolder: Payments
		lineageTag: f0000003-0m03-0000-0000-000000000001

	/// Total outgoing converted to TRY
	measure 'Total Outgoing TRY' =
			CALCULATE (
				SUMX (
					Payment,
					Payment[Amount] *
					LOOKUPVALUE (
						'Exchange Rate'[forex_selling],
						'Exchange Rate'[base_currency], RELATED ( Currency[CurrencyCode] ),
						'Exchange Rate'[date], RELATED ( 'Date'[Date] ),
						1
					)
				),
				Payment[Direction] = "outgoing"
			)
		formatString: ₺#,##0.00
		displayFolder: Payments
		lineageTag: f0000003-0m04-0000-0000-000000000001

	/// Payment coverage: outgoing payments / total bills
	measure 'Payment Coverage %' =
			DIVIDE ( [Total Outgoing TRY], [Total Bills TRY] )
		formatString: 0.0%
		displayFolder: Payments
		lineageTag: f0000003-0m05-0000-0000-000000000001

	partition Payment = m
		mode: import
		queryGroup: Tables
		source =
				let
				    Source = Sql.Database(SqlEndpoint, Database),
				    Data = Source{[Schema="dbo",Item="payment"]}[Data]
				in
				    Data
