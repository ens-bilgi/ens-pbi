# Azure Entra ID (required for Power BI API access)
# See docs/azure-setup.md for step-by-step instructions
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Power BI workspace IDs (optional defaults)
POWERBI_WORKSPACE_ID=your-workspace-id

# Neon PostgreSQL (EnS Finance production database)
NEON_HOST=your-neon-host.neon.tech
NEON_DB=neondb
NEON_USER=your-neon-user
NEON_PASSWORD=your-neon-password
